{
  "compilerOptions": {
    // Target & Libs
    "lib": ["dom", "dom.iterable", "esnext"],
    "target": "ES2020",
    
    // Modules
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    
    // Strict Type Checking
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    
    // Additional Safety (selective)
    "noUnusedLocals": false,  // Allow unused in dev
    "noUnusedParameters": false,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": false,  // Too strict for existing code
    "exactOptionalPropertyTypes": false,  // Conflicts with undefined
    "noImplicitOverride": true,
    
    // File System Safety
    "forceConsistentCasingInFileNames": true,
    
    // Build
    "noEmit": true,
    "incremental": true,
    
    // Next.js Plugin
    "plugins": [
      {
        "name": "next"
      }
    ],
    
    // Path Aliases
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    
    // Module Resolution
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
