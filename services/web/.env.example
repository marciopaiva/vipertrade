# ===================================
# ViperTrade Web - Environment Variables
# ===================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git!

# ===================================
# API Configuration
# ===================================

# Backend API URL (HTTP)
NEXT_PUBLIC_API_URL=http://localhost:8080

# WebSocket URL (Real-time data)
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws

# ===================================
# Trading Configuration
# ===================================

# Trading Mode: paper | testnet | mainnet
NEXT_PUBLIC_TRADING_MODE=paper

# Default trading profile: CONSERVATIVE | MEDIUM | AGGRESSIVE
NEXT_PUBLIC_TRADING_PROFILE=MEDIUM

# ===================================
# Feature Flags
# ===================================

# Enable WebSocket connections for real-time data
NEXT_PUBLIC_ENABLE_WEBSOCKET=true

# Enable analytics and charts
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# Enable real-time position updates
NEXT_PUBLIC_ENABLE_LIVE_POSITIONS=true

# Enable trade notifications
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true

# ===================================
# UI Configuration
# ===================================

# Dashboard refresh interval (milliseconds)
NEXT_PUBLIC_REFRESH_INTERVAL=5000

# Number of trades to show per page
NEXT_PUBLIC_TRADES_PER_PAGE=10

# Enable dark mode by default
NEXT_PUBLIC_DARK_MODE=true

# ===================================
# Docker Build Configuration
# ===================================

# Enable BuildKit for faster builds
DOCKER_BUILDKIT=1

# Node version for build
NODE_VERSION=20

# ===================================
# Development
# ===================================

# Enable React strict mode
NEXT_PUBLIC_REACT_STRICT_MODE=true

# Enable TypeScript strict mode
NEXT_PUBLIC_TYPESCRIPT_STRICT=true

# Enable ESLint checks
NEXT_PUBLIC_ESLINT_CHECKS=true

# ===================================
# Production Overrides
# ===================================

# Production API URL (uncomment and set for production)
# NEXT_PUBLIC_API_URL=https://api.vipertrade.com

# Production WebSocket URL
# NEXT_PUBLIC_WS_URL=wss://ws.vipertrade.com

# Production trading mode (should be mainnet)
# NEXT_PUBLIC_TRADING_MODE=mainnet
