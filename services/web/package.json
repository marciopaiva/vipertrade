{
  "name": "vipertrade-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "lint:check": "next lint --dir .",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "docker:build": "docker build -t vipertrade-web:latest .",
    "docker:run": "docker run -p 3000:3000 --env-file .env vipertrade-web:latest",
    "docker:dev": "docker-compose up -d",
    "docker:logs": "docker-compose logs -f web",
    "docker:stop": "docker-compose down",
    "docker:restart": "docker-compose restart web",
    "docker:clean": "docker-compose down -v && docker system prune -f",
    "analyze": "ANALYZE=true next build",
    "serve": "npx serve@latest out"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.89.2",
    "@tanstack/react-query-devtools": "^5.28.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "next": "^16.1.7",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.62.0",
    "recharts": "^3.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "ws": "^8.18.3",
    "zod": "^3.25.76",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@hookform/resolvers": "^5.2.1",
    "@types/node": "25.3.5",
    "@types/react": "19.2.14",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.57.0",
    "eslint-config-next": "^16.1.7",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "postcss": "^8.5.8",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.19",
    "typescript": "5.9.3",
    "vitest": "^4.1.0"
  }
}
