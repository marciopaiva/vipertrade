# compose/.env.example
# ⚠️  TEMPLATE - COPIE PARA .env E PREENCHA COM VALORES REAIS
# NUNCA commitar o arquivo .env real no Git!

# ═══════════════════════════════════════════════════════════
# BYBIT API CONFIGURATION
# ═══════════════════════════════════════════════════════════
# TRADING_MODE drives the runtime source of truth:
# - PAPER   => market data from mainnet, wallet/positions simulated in DB, no exchange orders
# - TESTNET => data and orders on Bybit testnet
# - MAINNET => data and orders on Bybit mainnet
BYBIT_ENV=testnet
BYBIT_TESTNET_API_KEY=your_testnet_api_key_here
BYBIT_TESTNET_API_SECRET=your_testnet_api_secret_here
BYBIT_MAINNET_API_KEY=your_mainnet_api_key_here
BYBIT_MAINNET_API_SECRET=your_mainnet_api_secret_here
# Legacy fallback. Leave empty unless you still need old variable names.
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_WS_PUBLIC=wss://stream-testnet.bybit.com/v5/public/linear
BYBIT_WS_PRIVATE=wss://stream-testnet.bybit.com/v5/private

# ═══════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════
DB_HOST=postgres
DB_PORT=5432
DB_NAME=vipertrade
DB_USER=viper
DB_PASSWORD=generate_strong_password_here

# ═══════════════════════════════════════════════════════════
# REDIS CONFIGURATION
# ═══════════════════════════════════════════════════════════
REDIS_HOST=redis
REDIS_PORT=6379

# ═══════════════════════════════════════════════════════════
# DISCORD NOTIFICATIONS
# ═══════════════════════════════════════════════════════════
DISCORD_WEBHOOK_CRITICAL=your_webhook_url_here
DISCORD_WEBHOOK_WARNING=your_webhook_url_here
DISCORD_WEBHOOK_INFO=your_webhook_url_here

# ═══════════════════════════════════════════════════════════
# TRADING CONFIGURATION
# ═══════════════════════════════════════════════════════════
TRADING_MODE=paper
TRADING_PROFILE=MEDIUM
INITIAL_CAPITAL_USD=100
RISK_PER_TRADE_PCT=1.25
WALLET_API_BASE_URL=http://api:8080
MAX_LEVERAGE=2
MAX_DAILY_LOSS_PCT=3
TRADING_PAIRS=DOGEUSDT,XRPUSDT,ADAUSDT,XLMUSDT

# ═══════════════════════════════════════════════════════════
# SMART COPY CONFIGURATION
# ═══════════════════════════════════════════════════════════
SMART_COPY_ENABLED=true
MIN_POSITION_USDT=5
MAX_POSITION_USDT=30
MAX_POSITION_CHANGE_PCT=0.30

# ═══════════════════════════════════════════════════════════
# TRAILING STOP CONFIGURATION
# ═══════════════════════════════════════════════════════════
TRAILING_STOP_ENABLED=true
TRAILING_CHECK_INTERVAL_MS=500
MAX_TRAILING_UPDATES_PER_MIN=10

# ═══════════════════════════════════════════════════════════
# TUPÃ CONFIGURATION (v0.8.0-rc)
# ═══════════════════════════════════════════════════════════
TUPA_VERSION=0.8.0-rc
TUPA_BACKEND=hybrid
TUPA_PIPELINE_PATH=/app/config/strategies/viper_smart_copy.tp
TUPA_AUDIT_PATH=/app/logs/audit
TUPA_SEED=42
PROFILE_CONFIG=/app/config/system/profiles.yaml
PYO3_USE_ABI3_FORWARD_COMPATIBILITY=1

# ═══════════════════════════════════════════════════════════
# SYSTEM CONFIGURATION
# ═══════════════════════════════════════════════════════════
LOG_LEVEL=info
HEALTH_CHECK_INTERVAL_MIN=15
RECONCILIATION_INTERVAL_MIN=5
ALERT_COOLDOWN_SEC=300

# ═══════════════════════════════════════════════════════════
# STANDARD BASE IMAGES (WSL/PODMAN)
# ═══════════════════════════════════════════════════════════
RUST_BUILDER_IMAGE=vipertrade-base-rust-builder:1.83
RUST_RUNTIME_IMAGE=vipertrade-base-rust-runtime:bookworm
STRATEGY_BUILDER_IMAGE=vipertrade-base-strategy-builder:1.83
STRATEGY_RUNTIME_IMAGE=vipertrade-base-strategy-runtime:3.12-bookworm
WEB_BASE_IMAGE=vipertrade-base-web-node:20-bookworm

# ═══════════════════════════════════════════════════════════
# WEB DASHBOARD (OPCIONAL)
# ═══════════════════════════════════════════════════════════
NEXTAUTH_SECRET=generate_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Executor controls
# EXECUTOR_ENABLE_LIVE_ORDERS is legacy; execution is derived from TRADING_MODE
EXECUTOR_ENABLE_LIVE_ORDERS=false
EXECUTOR_PAPER_MAX_OPEN_POSITIONS=4
BYBIT_RECV_WINDOW=5000
EXECUTOR_LIVE_SYMBOL_ALLOWLIST=DOGEUSDT
EXECUTOR_RECONCILE_FIX=false

# API operator control auth
OPERATOR_API_TOKEN=
OPERATOR_AUTH_MODE=token
BYBIT_ACCOUNT_TYPE=UNIFIED
